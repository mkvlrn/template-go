{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended"],
	"packageRules": [
		{
			"matchPackageNames": ["github:**"],
			"groupName": "Toolchain (mise)"
		},
		{
			"matchManagers": ["mise"],
			"groupName": "Toolchain (mise)"
		},
		{
			"matchManagers": ["gomod"],
			"groupName": "Dependencies (go)"
		},
		{
			"matchManagers": ["github-actions"],
			"groupName": "GitHub Actions"
		}
	],
	"customManagers": [
		{
			"customType": "regex",
			"fileMatch": ["(^|/|\\.)mise\\.toml$"],
			"matchStrings": [
				"\"github:(?<packageName>[^\"]+)\"\\s*=\\s*\"(?<currentValue>[^\"]+)\""
			],
			"datasourceTemplate": "github-releases"
		}
	],
	"rangeStrategy": "bump",
	"prHourlyLimit": 0,
	"prConcurrentLimit": 0,
	"dependencyDashboard": true
}
